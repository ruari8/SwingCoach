# Cloudflare R2 Configuration
R2_ACCOUNT_ID=your_account_id_here
R2_ACCESS_KEY_ID=your_access_key_here
R2_SECRET_ACCESS_KEY=your_secret_key_here
R2_BUCKET_NAME=swing-coach
# Defaults to true. Set false only as a temporary local workaround for SSL cert-store issues.
R2_VERIFY_SSL=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# SAM3 Model Path (optional)
# If not set, will check backend/models/models--facebook--sam3/ then HuggingFace cache
# SAM3_MODEL_PATH=/path/to/sam3/checkpoint
